// ==========================================
// เครื่องตัดท่อหด + ESP NOW Remote Receiver
// ==========================================

#include <Wire.h>
#include <LiquidCrystal_I2C.h>
#include <Stepper.h>
#include <ESP32Servo.h>
#include <WiFi.h>
#include <esp_now.h>

// ---------------- LCD ----------------
LiquidCrystal_I2C lcd(0x27, 16, 2);

const uint8_t KEYPAD_ADDRESS = 0x20;
const uint8_t BUTTON_ADDRESS = 0x38;

// ---------------- Stepper ----------------
#define SM_IN1 19
#define SM_IN2 18
#define SM_IN3 5
#define SM_IN4 17

const int stepsPerRevolution = 2048;

Stepper myStepper(stepsPerRevolution, SM_IN1, SM_IN3, SM_IN2, SM_IN4);

const float STEPS_PER_MM = 65.0;

// ---------------- Servo ----------------
#define SERVO_PIN 16
Servo myServo;

// ---------------- IR ----------------
#define IR_SENSOR1 35
#define IR_SENSOR2 32
#define IR_SENSOR3 33

// ---------------- Keypad ----------------
const uint8_t rowPins[4] = {1,6,5,3};
const uint8_t colPins[3] = {2,0,4};

const char keys[4][3] = {
{'1','2','3'},
{'4','5','6'},
{'7','8','9'},
{'*','0','#'}
};

// ---------------- ESP NOW ----------------

typedef struct {
  char key;
} RemoteData;

RemoteData remoteData;

char remoteKey = 'N';

void OnDataRecv(const esp_now_recv_info *info, const uint8_t *data, int len){

  memcpy(&remoteData,data,sizeof(remoteData));

  remoteKey = remoteData.key;

  Serial.print("Remote Key: ");
  Serial.println(remoteKey);
}

// ---------------- UI ----------------

int uiState = 0;

String inputLength="";
String inputQty="";

char lastKey='N';

int lastTubeLevel=-1;

bool lastBtnOk=HIGH,lastBtnCancel=HIGH,lastBtnBack=HIGH,lastBtnNext=HIGH;

// ----------------------------------------------------

void setup(){

Serial.begin(115200);

Wire.begin(21,22);

// LCD
lcd.init();
lcd.backlight();

// Button IC
Wire.beginTransmission(BUTTON_ADDRESS);
Wire.write(0xFF);
Wire.endTransmission();

// IR
pinMode(IR_SENSOR1,INPUT);
pinMode(IR_SENSOR2,INPUT);
pinMode(IR_SENSOR3,INPUT);

// Stepper
myStepper.setSpeed(12);

// Servo
myServo.setPeriodHertz(50);
myServo.attach(SERVO_PIN,400,2400);
myServo.write(0);

// ---------------- ESP NOW ----------------

WiFi.mode(WIFI_STA);

if(esp_now_init()!=ESP_OK){
Serial.println("ESP NOW INIT FAIL");
return;
}

esp_now_register_recv_cb(OnDataRecv);

Serial.println("ESP NOW READY");

// -----------------------------------------

updateDisplay();

}

// ----------------------------------------------------

int getTubeLevel(){

int count=0;

if(digitalRead(IR_SENSOR1)==LOW) count++;
if(digitalRead(IR_SENSOR2)==LOW) count++;
if(digitalRead(IR_SENSOR3)==LOW) count++;

return count;

}

// ----------------------------------------------------

char readKeypad(){

for(int r=0;r<4;r++){

uint8_t writeByte=0xFF;

writeByte&=~(1<<rowPins[r]);

Wire.beginTransmission(KEYPAD_ADDRESS);
Wire.write(writeByte);
if(Wire.endTransmission()!=0) return 'E';

Wire.requestFrom((uint16_t)KEYPAD_ADDRESS,(uint8_t)1);

if(Wire.available()){

uint8_t readByte=Wire.read();

for(int c=0;c<3;c++){

if((readByte&(1<<colPins[c]))==0){

Wire.beginTransmission(KEYPAD_ADDRESS);
Wire.write(0xFF);
Wire.endTransmission();

return keys[r][c];

}

}

}

}

Wire.beginTransmission(KEYPAD_ADDRESS);
Wire.write(0xFF);
Wire.endTransmission();

return 'N';

}

// ----------------------------------------------------

void updateDisplay(){

lcd.clear();

int tubeLvl=getTubeLevel();

String tubeStr="";

if(tubeLvl==3) tubeStr="Full";
else if(tubeLvl==2) tubeStr="Mid ";
else if(tubeLvl==1) tubeStr="Low ";
else tubeStr="Emp!";

if(uiState==0){

lcd.setCursor(0,0);
lcd.print("Len(mm):");

lcd.setCursor(12,0);
lcd.print(tubeStr);

lcd.setCursor(0,1);
lcd.print("> "+inputLength);

}

else if(uiState==1){

lcd.setCursor(0,0);
lcd.print("Qty(pcs):");

lcd.setCursor(12,0);
lcd.print(tubeStr);

lcd.setCursor(0,1);
lcd.print("> "+inputQty);

}

else if(uiState==2){

lcd.setCursor(0,0);
lcd.print("L:"+inputLength+"mm Q:"+inputQty);

lcd.setCursor(0,1);
lcd.print("Press OK to Cut!");

}

}

// ----------------------------------------------------

void loop(){

// -------- Tube level --------

int currentTubeLevel=getTubeLevel();

if(currentTubeLevel!=lastTubeLevel && (uiState==0 || uiState==1)){

lastTubeLevel=currentTubeLevel;

updateDisplay();

}

// -------- keypad --------

char customKey = readKeypad();

// รับค่าจาก remote
if(remoteKey!='N'){
customKey = remoteKey;
remoteKey='N';
}

if(customKey!='N' && customKey!='E' && customKey!=lastKey){

if(customKey>='0' && customKey<='9'){

if(uiState==0 && inputLength.length()<4){

inputLength+=customKey;

updateDisplay();

}

else if(uiState==1 && inputQty.length()<4){

inputQty+=customKey;

updateDisplay();

}

}

else if(customKey=='*'){

if(uiState==0 && inputLength.length()>0){

inputLength.remove(inputLength.length()-1);

updateDisplay();

}

else if(uiState==1 && inputQty.length()>0){

inputQty.remove(inputQty.length()-1);

updateDisplay();

}

}

delay(50);

}

lastKey=(customKey=='N')?'N':customKey;

// -------- Buttons --------

bool curOk=HIGH,curCancel=HIGH,curBack=HIGH,curNext=HIGH;

Wire.requestFrom((uint16_t)BUTTON_ADDRESS,(uint8_t)1);

if(Wire.available()){

uint8_t btnState=Wire.read();

curOk=(btnState&(1<<0))?HIGH:LOW;
curCancel=(btnState&(1<<1))?HIGH:LOW;
curBack=(btnState&(1<<2))?HIGH:LOW;
curNext=(btnState&(1<<3))?HIGH:LOW;

}

// NEXT

if(lastBtnNext==HIGH && curNext==LOW){

if(uiState==0){

if(inputLength==""){

lcd.clear();
lcd.print("Pls specify size");
delay(1500);
updateDisplay();

}

else{

uiState=1;
updateDisplay();

}

}

delay(50);

}

// OK

if(lastBtnOk==HIGH && curOk==LOW){

if(uiState==1){

if(inputQty==""){

lcd.clear();
lcd.print("Please fill qty!");
delay(1500);
updateDisplay();

}

else{

uiState=2;
updateDisplay();

}

}

delay(50);

}

// BACK

if(lastBtnBack==HIGH && curBack==LOW){

if(uiState==1){
uiState=0;
updateDisplay();
}

else if(uiState==2){
uiState=1;
updateDisplay();
}

delay(50);

}

// CANCEL

if(lastBtnCancel==HIGH && curCancel==LOW){

inputLength="";
inputQty="";
uiState=0;

lastTubeLevel=-1;

updateDisplay();

delay(50);

}

lastBtnNext=curNext;
lastBtnOk=curOk;
lastBtnBack=curBack;
lastBtnCancel=curCancel;

delay(10);

}
